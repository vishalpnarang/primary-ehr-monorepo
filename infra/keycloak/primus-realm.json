  "loginTheme": "keycloak",
  "accountTheme": "keycloak.v2",
  "adminTheme": "keycloak",
  "emailTheme": "keycloak",

  "eventsEnabled": true,
  "eventsExpiration": 2592000,
  "enabledEventTypes": [
