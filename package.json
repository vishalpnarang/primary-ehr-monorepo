{
  "name": "primus-ehr",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/shared",
    "apps/provider-portal",
    "apps/patient-portal"
  ],
  "scripts": {
    "dev:provider": "npm run dev --workspace=apps/provider-portal",
    "dev:patient": "npm run dev --workspace=apps/patient-portal",
    "build:provider": "npm run build --workspace=apps/provider-portal",
    "build:patient": "npm run build --workspace=apps/patient-portal",
    "build": "npm run build:provider && npm run build:patient",
    "test": "npm run test --workspace=apps/provider-portal",
    "test:e2e": "npx playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "sonar": "sonar-scanner -Dsonar.host.url=http://localhost:9000 -Dsonar.token=${SONAR_TOKEN}"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
